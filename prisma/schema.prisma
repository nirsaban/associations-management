// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum PlatformRole {
  SUPER_ADMIN
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

enum SystemRole {
  ADMIN        // Organization administrator
  USER         // Regular user
}

enum GroupRole {
  MEMBER
  MANAGER
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum OrderStatus {
  DRAFT
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  CHECK
  CASH
  OTHER
}

enum ReminderChannel {
  SMS
  PUSH
  WHATSAPP
}

enum NotificationType {
  ORDER_CREATED
  ORDER_COMPLETED
  PAYMENT_DUE
  PAYMENT_RECEIVED
  USER_INVITED
  GROUP_CREATED
  DISTRIBUTION_STARTED
  DISTRIBUTION_COMPLETED
  SYSTEM_ALERT
}

enum NotificationChannel {
  PUSH
  WHATSAPP
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  SKIPPED
}

// ============================================================================
// ORGANIZATION & USERS
// ============================================================================

model Organization {
  id              String   @id @default(cuid())
  name            String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(100)
  contactPhone    String?  @db.VarChar(20)
  contactEmail    String?  @db.VarChar(255)
  address         String?  @db.Text
  logoUrl         String?  @db.VarChar(500)
  description     String?  @db.Text
  paymentLink     String?  @db.VarChar(500)
  paymentDescription String? @db.Text
  facebookUrl     String?  @db.VarChar(500)
  instagramUrl    String?  @db.VarChar(500)
  whatsappUrl     String?  @db.VarChar(500)
  websiteUrl      String?  @db.VarChar(500)
  settings        Json?    @default("{}")
  status          OrganizationStatus @default(ACTIVE)
  setupCompleted  Boolean  @default(false)
  createdBySuperAdminId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users                   User[]
  groups                  Group[]
  families                Family[]
  groupMemberships        GroupMembership[]
  weeklyOrders            WeeklyOrder[]
  weeklyDistributorAssignments WeeklyDistributorAssignment[]
  payments                Payment[]
  monthlyPaymentStatuses  MonthlyPaymentStatus[]
  paymentReminders        PaymentReminder[]
  notifications           Notification[]
  pushSubscriptions       PushSubscription[]
  webhookEvents           WebhookEvent[]

  @@index([createdAt])
  @@index([status])
  @@map("organizations")
}

model User {
  id                     String        @id @default(cuid())
  organizationId         String?       // Nullable for SUPER_ADMIN users (platform admins)
  phone                  String        @db.VarChar(20)
  fullName               String        @db.VarChar(255)
  email                  String?       @db.VarChar(255)
  avatarUrl              String?       @db.VarChar(500)
  platformRole           PlatformRole? // Only set for SUPER_ADMIN
  systemRole             SystemRole    @default(USER)
  isActive               Boolean       @default(true)
  isImported             Boolean       @default(false)
  registrationCompleted  Boolean       @default(false)
  activationCompleted    Boolean       @default(false)
  groupChoiceLocked      Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  organization              Organization?               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  managedGroups             Group[]                     @relation("GroupManager")
  groupMemberships          GroupMembership[]
  webauthnCredentials       WebauthnCredential[]
  weeklyOrdersCreated       WeeklyOrder[]               @relation("OrderCreatedBy")
  weeklyDistributorAssignment WeeklyDistributorAssignment? @relation("AssignedDistributor")
  weeklyDistributorAssignedBy WeeklyDistributorAssignment[] @relation("AssignedBy")
  payments                  Payment[]
  monthlyPaymentStatuses    MonthlyPaymentStatus[]
  paymentReminders          PaymentReminder[]
  notifications             Notification[]
  pushSubscriptions         PushSubscription[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([phone])
  @@index([createdAt])
  @@index([isActive])
  @@map("users")
}

// ============================================================================
// GROUPS & MEMBERSHIPS
// ============================================================================

model Group {
  id             String   @id @default(cuid())
  organizationId String
  name           String   @db.VarChar(255)
  managerUserId  String?
  isActive       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  organization                 Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manager                      User?                         @relation("GroupManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  memberships                  GroupMembership[]
  families                     Family[]
  weeklyOrders                 WeeklyOrder[]
  weeklyDistributorAssignments WeeklyDistributorAssignment[]

  @@index([organizationId])
  @@index([managerUserId])
  @@index([createdAt])
  @@map("groups")
}

model GroupMembership {
  id             String          @id @default(cuid())
  organizationId String
  groupId        String
  userId         String
  role           GroupRole        @default(MEMBER)
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime        @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([organizationId])
  @@index([groupId])
  @@index([userId])
  @@index([createdAt])
  @@map("group_memberships")
}

// ============================================================================
// FAMILIES & DISTRIBUTION
// ============================================================================

model Family {
  id                 String   @id @default(cuid())
  organizationId     String
  groupId            String?  // Optional: family may belong to a group
  familyName         String   @db.VarChar(255)
  contactName        String?  @db.VarChar(255)
  address            String?  @db.Text
  contactPhone       String?  @db.VarChar(20)
  childrenMinorCount Int?
  totalMemberCount   Int?
  notes              String?  @db.Text
  metadataJson       Json?    @default("{}")
  status             String   @default("active") @db.VarChar(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group        Group?         @relation(fields: [groupId], references: [id], onDelete: SetNull)
  weeklyOrders WeeklyOrder[]

  @@unique([organizationId, familyName])
  @@index([organizationId])
  @@index([groupId])
  @@index([createdAt])
  @@map("families")
}

// ============================================================================
// WEEKLY ORDERS & DISTRIBUTION
// ============================================================================

model WeeklyOrder {
  id               String      @id @default(cuid())
  organizationId   String
  groupId          String
  familyId         String
  weekKey          String      @db.VarChar(10)  // Format: "2026-W16"
  createdByUserId  String?
  shoppingListJson Json        @default("[]")
  notes            String?     @db.Text
  status           OrderStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group         Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  family        Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdByUser User?        @relation("OrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([familyId, weekKey])
  @@index([organizationId])
  @@index([groupId])
  @@index([familyId])
  @@index([weekKey])
  @@index([status])
  @@index([createdAt])
  @@map("weekly_orders")
}

model WeeklyDistributorAssignment {
  id             String @id @default(cuid())
  organizationId String
  groupId        String
  weekKey        String @db.VarChar(10) // Format: "2026-W16"
  assignedUserId String @unique
  assignedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignedUser User         @relation("AssignedDistributor", fields: [assignedUserId], references: [id], onDelete: Cascade)
  assignedBy   User?        @relation("AssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([groupId, weekKey])
  @@index([organizationId])
  @@index([groupId])
  @@index([weekKey])
  @@map("weekly_distributor_assignments")
}

// ============================================================================
// PAYMENTS & REMINDERS
// ============================================================================

model Payment {
  id                    String        @id @default(cuid())
  organizationId        String
  userId                String
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("ILS") @db.VarChar(3)
  monthKey              String        @db.VarChar(7)  // Format: "2026-04"
  paymentDate           DateTime?
  source                String?       @db.VarChar(100)
  externalTransactionId String?       @db.VarChar(255)
  status                PaymentStatus @default(PENDING)
  rawWebhookPayload     Json?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  monthlyPaymentStatus MonthlyPaymentStatus?

  @@unique([externalTransactionId])
  @@index([organizationId])
  @@index([userId])
  @@index([monthKey])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model MonthlyPaymentStatus {
  id              String    @id @default(cuid())
  organizationId  String
  userId          String
  monthKey        String    @db.VarChar(7) // Format: "2026-04"
  isPaid          Boolean   @default(false)
  paidAt          DateTime?
  paymentId       String?   @unique
  reminderCount   Int       @default(0)
  lastReminderAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment      Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([userId, monthKey])
  @@index([organizationId])
  @@index([userId])
  @@index([monthKey])
  @@index([isPaid])
  @@map("monthly_payment_statuses")
}

model PaymentReminder {
  id             String          @id @default(cuid())
  organizationId String
  userId         String
  monthKey       String          @db.VarChar(7) // Format: "2026-04"
  reminderNumber Int             // 1, 2, or 3
  channel        ReminderChannel
  status         ReminderStatus  @default(PENDING)
  sentAt         DateTime?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey, reminderNumber])
  @@index([organizationId])
  @@index([userId])
  @@index([monthKey])
  @@index([sentAt])
  @@map("payment_reminders")
}

// ============================================================================
// NOTIFICATIONS & PUSH
// ============================================================================

model Notification {
  id             String              @id @default(cuid())
  organizationId String
  userId         String
  type           NotificationType
  title          String              @db.VarChar(255)
  body           String              @db.Text
  channel        NotificationChannel @default(PUSH)
  status         NotificationStatus  @default(PENDING)
  sentAt         DateTime?
  metadataJson   Json?               @default("{}")

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

model PushSubscription {
  id             String  @id @default(cuid())
  organizationId String? // Nullable for SUPER_ADMIN users (no org)
  userId         String
  endpoint       String  @db.Text
  p256dh         String  @db.Text
  auth           String  @db.Text
  deviceInfo     Json?   @default("{}")
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([organizationId])
  @@index([userId])
  @@index([isActive])
  @@map("push_subscriptions")
}

// ============================================================================
// OTP & AUTH
// ============================================================================

model OtpCode {
  id           String    @id @default(cuid())
  phone        String    @db.VarChar(20)
  otpHash      String    @db.VarChar(255)
  purpose      String    @default("login") @db.VarChar(50)
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int       @default(0)

  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_codes")
}

// ============================================================================
// WEBAUTHN CREDENTIALS
// ============================================================================

model WebauthnCredential {
  id              String   @id @default(cuid())
  userId          String
  credentialId    String   @unique @db.Text
  publicKey       Bytes
  counter         BigInt   @default(0)
  deviceType      String?  @db.VarChar(50)  // "singleDevice" | "multiDevice"
  backedUp        Boolean  @default(false)
  transports      String[] @default([])     // e.g. ["internal", "hybrid"]
  deviceName      String?  @db.VarChar(255) // e.g. "iPhone 15 Pro"

  createdAt  DateTime @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("webauthn_credentials")
}

// ============================================================================
// WEBHOOKS
// ============================================================================

model WebhookEvent {
  id             String             @id @default(cuid())
  organizationId String?            // Nullable: platform-level webhooks may not have org
  provider       String             @db.VarChar(100)
  eventId        String?            @db.VarChar(255)
  eventType      String             @db.VarChar(100)
  status         WebhookEventStatus @default(RECEIVED)
  rawPayload     Json
  processedAt    DateTime?

  createdAt DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([provider])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_events")
}
