// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum PlatformRole {
  SUPER_ADMIN
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

enum SystemRole {
  ADMIN        // Organization administrator
  USER         // Regular user
}

enum GroupRole {
  MEMBER
  MANAGER
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum OrderStatus {
  DRAFT
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  CHECK
  CASH
  OTHER
}

enum ReminderChannel {
  SMS
  PUSH
  WHATSAPP
}

enum NotificationType {
  ORDER_CREATED
  ORDER_COMPLETED
  PAYMENT_DUE
  PAYMENT_RECEIVED
  USER_INVITED
  GROUP_CREATED
  DISTRIBUTION_STARTED
  DISTRIBUTION_COMPLETED
  SYSTEM_ALERT
}

enum NotificationChannel {
  PUSH
  WHATSAPP
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  SKIPPED
}

enum AlertAudience {
  ALL_USERS
  GROUP_MANAGERS
}

enum AssetKind {
  IMAGE
  VIDEO
}

enum LandingPageTheme {
  WARM
  MODERN
  MINIMAL
  BOLD
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================================
// ORGANIZATION & USERS
// ============================================================================

model Organization {
  id              String   @id @default(cuid())
  name            String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(100)
  legalName       String?  @db.VarChar(255)
  taxId           String?  @db.VarChar(50)
  contactPhone    String?  @db.VarChar(20)
  contactEmail    String?  @db.VarChar(255)
  address         String?  @db.Text
  addressLine2    String?  @db.VarChar(255)
  city            String?  @db.VarChar(100)
  postalCode      String?  @db.VarChar(20)
  country         String   @default("IL") @db.VarChar(10)
  logoUrl         String?  @db.VarChar(500)
  logoAssetId     String?
  primaryColor    String   @default("#2563eb") @db.VarChar(20)
  accentColor     String   @default("#f59e0b") @db.VarChar(20)
  aboutShort      String?  @db.VarChar(280)
  aboutLong       String?  @db.Text
  description     String?  @db.Text
  paymentLink     String?  @db.VarChar(500)
  defaultPaymentLink String? @db.VarChar(500)
  paymentDescription String? @db.Text
  growUserId      String?  @db.VarChar(100)
  growPageCode    String?  @db.VarChar(100)
  facebookUrl     String?  @db.VarChar(500)
  instagramUrl    String?  @db.VarChar(500)
  whatsappUrl     String?  @db.VarChar(500)
  websiteUrl      String?  @db.VarChar(500)
  settings        Json?    @default("{}")
  status          OrganizationStatus @default(ACTIVE)
  setupCompleted  Boolean  @default(false)
  createdBySuperAdminId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  logoAsset               Asset?   @relation("OrgLogo", fields: [logoAssetId], references: [id], onDelete: SetNull)
  users                   User[]
  groups                  Group[]
  families                Family[]
  groupMemberships        GroupMembership[]
  weeklyOrders            WeeklyOrder[]
  weeklyDistributorAssignments WeeklyDistributorAssignment[]
  payments                Payment[]
  monthlyPaymentStatuses  MonthlyPaymentStatus[]
  paymentReminders        PaymentReminder[]
  notifications           Notification[]
  pushSubscriptions       PushSubscription[]
  webhookEvents           WebhookEvent[]
  alerts                  Alert[]
  weeklyFamilyDeliveries  WeeklyFamilyDelivery[]
  assets                  Asset[]  @relation("OrgAssets")
  landingPage             LandingPage?
  reviews                 Review[]
  landingLeads            LandingLead[]
  referrals               Referral[]

  @@index([createdAt])
  @@index([status])
  @@map("organizations")
}

model User {
  id                     String        @id @default(cuid())
  organizationId         String?       // Nullable for SUPER_ADMIN users (platform admins)
  phone                  String        @db.VarChar(20)
  fullName               String        @db.VarChar(255)
  email                  String?       @db.VarChar(255)
  avatarUrl              String?       @db.VarChar(500)
  platformRole           PlatformRole? // Only set for SUPER_ADMIN
  systemRole             SystemRole    @default(USER)
  isActive               Boolean       @default(true)
  isImported             Boolean       @default(false)
  registrationCompleted  Boolean       @default(false)
  activationCompleted    Boolean       @default(false)
  groupChoiceLocked      Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  organization              Organization?               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  managedGroups             Group[]                     @relation("GroupManager")
  groupMemberships          GroupMembership[]
  webauthnCredentials       WebauthnCredential[]
  weeklyOrdersCreated       WeeklyOrder[]               @relation("OrderCreatedBy")
  weeklyDistributorAssignments WeeklyDistributorAssignment[] @relation("AssignedDistributor")
  weeklyDistributorAssignedBy WeeklyDistributorAssignment[] @relation("AssignedBy")
  payments                  Payment[]
  monthlyPaymentStatuses    MonthlyPaymentStatus[]
  paymentReminders          PaymentReminder[]
  notifications             Notification[]
  pushSubscriptions         PushSubscription[]
  alertsPublished           Alert[]             @relation("AlertsPublishedBy")
  deliveriesMarked          WeeklyFamilyDelivery[] @relation("DeliveriesMarkedBy")
  referrals                 Referral[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([phone])
  @@index([createdAt])
  @@index([isActive])
  @@map("users")
}

// ============================================================================
// GROUPS & MEMBERSHIPS
// ============================================================================

model Group {
  id             String   @id @default(cuid())
  organizationId String
  name           String   @db.VarChar(255)
  managerUserId  String?
  isActive       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  organization                 Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manager                      User?                         @relation("GroupManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  memberships                  GroupMembership[]
  families                     Family[]
  weeklyOrders                 WeeklyOrder[]
  weeklyDistributorAssignments WeeklyDistributorAssignment[]

  @@index([organizationId])
  @@index([managerUserId])
  @@index([createdAt])
  @@map("groups")
}

model GroupMembership {
  id             String          @id @default(cuid())
  organizationId String
  groupId        String
  userId         String
  role           GroupRole        @default(MEMBER)
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime        @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([organizationId])
  @@index([groupId])
  @@index([userId])
  @@index([createdAt])
  @@map("group_memberships")
}

// ============================================================================
// FAMILIES & DISTRIBUTION
// ============================================================================

model Family {
  id                 String   @id @default(cuid())
  organizationId     String
  groupId            String?  // Optional: family may belong to a group
  familyName         String   @db.VarChar(255)
  contactName        String?  @db.VarChar(255)
  address            String?  @db.Text
  contactPhone       String?  @db.VarChar(20)
  childrenMinorCount Int?
  totalMemberCount   Int?
  notes              String?  @db.Text
  metadataJson       Json?    @default("{}")
  status             String   @default("active") @db.VarChar(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group        Group?         @relation(fields: [groupId], references: [id], onDelete: SetNull)
  weeklyOrders WeeklyOrder[]
  deliveries   WeeklyFamilyDelivery[]

  @@unique([organizationId, familyName])
  @@index([organizationId])
  @@index([groupId])
  @@index([createdAt])
  @@map("families")
}

// ============================================================================
// WEEKLY ORDERS & DISTRIBUTION
// ============================================================================

model WeeklyOrder {
  id               String      @id @default(cuid())
  organizationId   String
  groupId          String
  familyId         String
  weekKey          String      @db.VarChar(10)  // Format: "2026-W16"
  createdByUserId  String?
  shoppingListJson Json        @default("[]")
  notes            String?     @db.Text
  status           OrderStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group         Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  family        Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdByUser User?        @relation("OrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([familyId, weekKey])
  @@index([organizationId])
  @@index([groupId])
  @@index([familyId])
  @@index([weekKey])
  @@index([status])
  @@index([createdAt])
  @@map("weekly_orders")
}

model WeeklyDistributorAssignment {
  id             String @id @default(cuid())
  organizationId String
  groupId        String
  weekKey        String @db.VarChar(10) // Format: "2026-W16"
  assignedUserId String
  assignedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignedUser User         @relation("AssignedDistributor", fields: [assignedUserId], references: [id], onDelete: Cascade)
  assignedBy   User?        @relation("AssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  deliveries   WeeklyFamilyDelivery[]

  @@unique([groupId, weekKey])
  @@index([organizationId])
  @@index([groupId])
  @@index([weekKey])
  @@map("weekly_distributor_assignments")
}

model WeeklyFamilyDelivery {
  id                           String   @id @default(cuid())
  organizationId               String
  weeklyDistributorAssignmentId String
  familyId                     String
  delivered                    Boolean  @default(false)
  deliveredAt                  DateTime?
  markedByUserId               String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization                 Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  weeklyDistributorAssignment  WeeklyDistributorAssignment @relation(fields: [weeklyDistributorAssignmentId], references: [id], onDelete: Cascade)
  family                       Family                      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  markedByUser                 User                        @relation("DeliveriesMarkedBy", fields: [markedByUserId], references: [id])

  @@unique([weeklyDistributorAssignmentId, familyId])
  @@index([organizationId, weeklyDistributorAssignmentId])
  @@index([familyId])
  @@map("weekly_family_deliveries")
}

// ============================================================================
// PAYMENTS & REMINDERS
// ============================================================================

model Payment {
  id                    String        @id @default(cuid())
  organizationId        String
  userId                String
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("ILS") @db.VarChar(3)
  monthKey              String        @db.VarChar(7)  // Format: "2026-04"
  paymentDate           DateTime?
  source                String?       @db.VarChar(100)
  externalTransactionId String?       @db.VarChar(255)
  status                PaymentStatus @default(PENDING)
  referralId            String?
  rawWebhookPayload     Json?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  referral     Referral?    @relation(fields: [referralId], references: [id], onDelete: SetNull)

  monthlyPaymentStatus MonthlyPaymentStatus?

  @@unique([externalTransactionId])
  @@index([organizationId])
  @@index([userId])
  @@index([monthKey])
  @@index([status])
  @@index([referralId])
  @@index([createdAt])
  @@map("payments")
}

model MonthlyPaymentStatus {
  id              String    @id @default(cuid())
  organizationId  String
  userId          String
  monthKey        String    @db.VarChar(7) // Format: "2026-04"
  isPaid          Boolean   @default(false)
  paidAt          DateTime?
  paymentId       String?   @unique
  reminderCount   Int       @default(0)
  lastReminderAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment      Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([userId, monthKey])
  @@index([organizationId])
  @@index([userId])
  @@index([monthKey])
  @@index([isPaid])
  @@map("monthly_payment_statuses")
}

model PaymentReminder {
  id             String          @id @default(cuid())
  organizationId String
  userId         String
  monthKey       String          @db.VarChar(7) // Format: "2026-04"
  reminderNumber Int             // 1, 2, or 3
  channel        ReminderChannel
  status         ReminderStatus  @default(PENDING)
  sentAt         DateTime?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey, reminderNumber])
  @@index([organizationId])
  @@index([userId])
  @@index([monthKey])
  @@index([sentAt])
  @@map("payment_reminders")
}

// ============================================================================
// NOTIFICATIONS & PUSH
// ============================================================================

model Notification {
  id             String              @id @default(cuid())
  organizationId String
  userId         String
  type           NotificationType
  title          String              @db.VarChar(255)
  body           String              @db.Text
  channel        NotificationChannel @default(PUSH)
  status         NotificationStatus  @default(PENDING)
  sentAt         DateTime?
  metadataJson   Json?               @default("{}")

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

model PushSubscription {
  id             String  @id @default(cuid())
  organizationId String? // Nullable for SUPER_ADMIN users (no org)
  userId         String
  endpoint       String  @db.Text
  p256dh         String  @db.Text
  auth           String  @db.Text
  deviceInfo     Json?   @default("{}")
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([organizationId])
  @@index([userId])
  @@index([isActive])
  @@map("push_subscriptions")
}

// ============================================================================
// OTP & AUTH
// ============================================================================

model OtpCode {
  id           String    @id @default(cuid())
  phone        String    @db.VarChar(20)
  otpHash      String    @db.VarChar(255)
  purpose      String    @default("login") @db.VarChar(50)
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int       @default(0)

  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_codes")
}

// ============================================================================
// WEBAUTHN CREDENTIALS
// ============================================================================

model WebauthnCredential {
  id              String   @id @default(cuid())
  userId          String
  credentialId    String   @unique @db.Text
  publicKey       Bytes
  counter         BigInt   @default(0)
  deviceType      String?  @db.VarChar(50)  // "singleDevice" | "multiDevice"
  backedUp        Boolean  @default(false)
  transports      String[] @default([])     // e.g. ["internal", "hybrid"]
  deviceName      String?  @db.VarChar(255) // e.g. "iPhone 15 Pro"

  createdAt  DateTime @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("webauthn_credentials")
}

// ============================================================================
// ALERTS
// ============================================================================

model Alert {
  id              String         @id @default(cuid())
  organizationId  String
  title           String         @db.VarChar(255)
  body            String         @db.Text
  audience        AlertAudience  @default(ALL_USERS)
  publishedById   String
  deliveredCount  Int            @default(0)
  recipientCount  Int            @default(0)
  publishedAt     DateTime       @default(now())
  expiresAt       DateTime?

  createdAt       DateTime       @default(now())

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  publishedBy     User           @relation("AlertsPublishedBy", fields: [publishedById], references: [id])

  @@index([organizationId, audience, publishedAt])
  @@index([organizationId])
  @@map("alerts")
}

// ============================================================================
// WEBHOOKS
// ============================================================================

model WebhookEvent {
  id             String             @id @default(cuid())
  organizationId String?            // Nullable: platform-level webhooks may not have org
  provider       String             @db.VarChar(100)
  eventId        String?            @db.VarChar(255)
  eventType      String             @db.VarChar(100)
  status         WebhookEventStatus @default(RECEIVED)
  rawPayload     Json
  processedAt    DateTime?

  createdAt DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([provider])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_events")
}

// ============================================================================
// ASSETS
// ============================================================================

model Asset {
  id             String    @id @default(cuid())
  organizationId String
  kind           AssetKind
  url            String    @db.VarChar(500)
  mime           String    @db.VarChar(100)
  bytes          Int       @default(0)
  width          Int?
  height         Int?
  createdById    String?

  createdAt DateTime @default(now())

  organization Organization @relation("OrgAssets", fields: [organizationId], references: [id], onDelete: Cascade)
  orgLogos     Organization[] @relation("OrgLogo")

  @@index([organizationId])
  @@map("assets")
}

// ============================================================================
// LANDING PAGES
// ============================================================================

model LandingPage {
  id             String           @id @default(cuid())
  organizationId String           @unique
  slug           String           @unique @db.VarChar(100)
  title          String           @db.VarChar(255)
  seoDescription String?          @db.VarChar(500)
  theme          LandingPageTheme @default(MODERN)
  published      Boolean          @default(false)
  publishedAt    DateTime?
  viewCount      Int              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sections     LandingPageSection[]

  @@index([slug])
  @@map("landing_pages")
}

model LandingPageSection {
  id            String  @id @default(cuid())
  landingPageId String
  type          String  @db.VarChar(50)
  position      Int
  data          Json    @default("{}")
  visible       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  landingPage LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  @@index([landingPageId, position])
  @@map("landing_page_sections")
}

// ============================================================================
// REVIEWS
// ============================================================================

model Review {
  id             String       @id @default(cuid())
  organizationId String
  authorName     String       @db.VarChar(255)
  authorEmail    String?      @db.VarChar(255)
  rating         Int
  body           String       @db.Text
  status         ReviewStatus @default(PENDING)
  submittedAt    DateTime     @default(now())
  approvedAt     DateTime?
  approvedById   String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@map("reviews")
}

// ============================================================================
// GROW PAYMENT PROCESS TRACKING
// ============================================================================

model GrowPaymentProcess {
  id             String   @id @default(cuid())
  organizationId String
  authCode       String   @db.VarChar(255)
  referralCode   String?  @db.VarChar(20)
  amount         Decimal  @db.Decimal(12, 2)
  slug           String   @db.VarChar(100)
  matched        Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([authCode])
  @@index([createdAt])
  @@map("grow_payment_processes")
}

// ============================================================================
// REFERRALS
// ============================================================================

model Referral {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  code           String   @db.VarChar(20)
  isActive       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks       ReferralClick[]
  payments     Payment[]

  @@unique([organizationId, code])
  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("referrals")
}

model ReferralClick {
  id         String   @id @default(cuid())
  referralId String
  ip         String?  @db.VarChar(45)
  userAgent  String?  @db.Text

  createdAt DateTime @default(now())

  referral Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  @@index([referralId])
  @@index([createdAt])
  @@map("referral_clicks")
}

// ============================================================================
// LANDING LEADS
// ============================================================================

model LandingLead {
  id              String  @id @default(cuid())
  organizationId  String
  name            String  @db.VarChar(255)
  email           String? @db.VarChar(255)
  phone           String? @db.VarChar(20)
  message         String? @db.Text
  sourceSectionId String?
  userAgent       String? @db.Text
  ip              String? @db.VarChar(45)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("landing_leads")
}
