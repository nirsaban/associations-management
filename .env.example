# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/amutot_dev

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3003/api/v1
API_PORT=3003
API_GLOBAL_PREFIX=api/v1

# Frontend Configuration
NEXT_PUBLIC_APP_NAME=Amutot
NEXT_PUBLIC_APP_URL=http://localhost:3010
NODE_ENV=development

# Logging
LOG_LEVEL=debug

# Email Service (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-email-password
SMTP_FROM=Amutot <noreply@example.com>

# AWS S3 (optional, for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=amutot-uploads

# Web Push Notifications (optional)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Payment Gateway (optional)
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_your-test-key
STRIPE_PUBLIC_KEY=pk_test_your-test-key
PAYMENT_WEBHOOK_SECRET=whsec_your-webhook-secret

# Airtable Integration (optional)
AIRTABLE_API_KEY=your-airtable-api-key
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Session/Cookie
SESSION_SECRET=your-session-secret-key-change-in-production

# Green API (WhatsApp OTP)
GREEN_API_ENABLED=false
GREEN_API_INSTANCE_ID=your-instance-id
GREEN_API_TOKEN=your-token
