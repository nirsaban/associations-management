{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@amutot/types": ["packages/types/src/index.ts"],
      "@amutot/types/*": ["packages/types/src/*"],
      "@amutot/ui": ["packages/ui/src/index.ts"],
      "@amutot/ui/*": ["packages/ui/src/*"],
      "@amutot/utils": ["packages/utils/src/index.ts"],
      "@amutot/utils/*": ["packages/utils/src/*"]
    }
  },
  "include": [],
  "references": [
    { "path": "apps/web" },
    { "path": "apps/api" },
    { "path": "packages/types" },
    { "path": "packages/ui" },
    { "path": "packages/utils" }
  ]
}
