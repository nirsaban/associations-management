# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3003/api/v1

# Analytics (optional)
NEXT_PUBLIC_GA_ID=

# Feature Flags
NEXT_PUBLIC_ENABLE_PWA=true

# Community module — professions / people search (Phase 1)
