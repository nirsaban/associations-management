# ============================================
# Amutot Platform — Production Environment
# Copy to /opt/miltech-association/.env
# NEVER commit this file with real values
# ============================================

# --- Postgres ---
POSTGRES_USER=amutot
POSTGRES_PASSWORD=          # Strong password: openssl rand -hex 24
POSTGRES_DB=amutot_db

# --- Database URL (used by backend + Prisma) ---
# Note: hostname is "postgres" (docker service name), port 5432 (internal)
DATABASE_URL=postgresql://amutot:YOUR_POSTGRES_PASSWORD@postgres:5432/amutot_db?schema=public

# --- Auth ---
JWT_SECRET=                 # Generate: openssl rand -hex 32

# --- Green API (WhatsApp OTP) ---
GREEN_API_INSTANCE=         # From your Green API dashboard
GREEN_API_TOKEN=            # From your Green API dashboard

# --- Push Notifications (VAPID) ---
# Generate both with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@amutot.cloud

# --- Image tag (optional, defaults to latest) ---
# IMAGE_TAG=latest
